{
  "Storage": {
    "Type": "S3",
    "LocalRootPath": "storage"
  },
  "Persistence": {
    "Provider": "DynamoDB",
    "JsonRootPath": "storage"
  },
  "AWS": {
    "Region": "us-east-2",
    "Profile": "saml",
    "SharedCredentialsFile": "",
    "AccessKey": "",
    "SecretKey": "",
    "SessionToken": "",
    "BucketName": "adp-gfr-edg-reports",
    "UseServerSideEncryption": true,
    "ServerSideEncryptionMethod": "AES256",
    "KmsKeyId": "",
    "DynamoDB": {
      "FindingsTableName": "gfr-edg-findings-dev",
      "JobAuditTableName": "gfr-edg-reports-dev",
      "RejectedRowsTableName": "gfr-edg-rejected-dev",
      "CheckpointsTableName": "gfr-ingestion-checkpoints-dev",
      "StagedFindingsTableName": "gfr-ingestion-staged-findings-dev"
    }
  },
  "IngestionProcessing": {
    "BatchSize": 1000,
    "MinBatchSize": 100,
    "MaxBatchSize": 10000,
    "EnableBatchCheckpointing": true,
    "MaxBatchPersistenceRetryCount": 3,
    "BatchPersistenceRetryDelayMilliseconds": 1000,
    "EnableParquetWorkingFile": true,
    "ParquetRowGroupSize": 10000
  },
  "QuarantineProcessing": {
    "RetentionYears": 10,
    "MaxRetryAttempts": 3,
    "RetryDelayMilliseconds": 1000,
    "SourceRootPath": "storage/source",
    "QuarantineRootPath": "storage/quarantine",
    "StubFileSuffix": "_Retention_Placeholder",
    "StubMessage": "This file was moved due to ADP retention policy. Contact admin to request restore.",
    "EnableRetentionCheck": true
  },

  // ─── Serilog configuration ──────────────────────────────────────────────────
  // Controls what gets logged, where it goes, and how it is formatted.
  // File sink:  src/RemediationTool.API/logs/remediationtool-YYYYMMDD.log
  //             Rolls over at midnight.  Keeps last 31 days.  Max 100 MB per file.
  // Console:    Plain text — easier to read in the terminal during development.
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      // Default level: Information — captures all normal operational events.
      // Override specific namespaces to reduce noise from frameworks.
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Amazon": "Warning"
      }
    },
    "WriteTo": [
      // ── Console sink ───────────────────────────────────────────────────────
      // Format: [HH:MM:SS LEVEL] SourceContext Message
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      // ── File sink ──────────────────────────────────────────────────────────
      // Writes to: logs/remediationtool-20260629.log (relative to the API project root)
      // Rolls daily at midnight.  31-day retention.  100 MB per file.
      // Shared: true  → safe for multi-process / IIS in-process hosting.
      {
        "Name": "File",
        "Args": {
          "path": "logs/remediationtool-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "flushToDiskInterval": "00:00:01",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{MachineName}] [{EnvironmentName}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    // ── Enrichers ─────────────────────────────────────────────────────────────
    // Properties added to every log entry automatically.
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    // ── Properties ────────────────────────────────────────────────────────────
    // Static properties added to every log entry.
    "Properties": {
      "Application": "GFR-RemediationTool"
    }
  }
}
