{
  "Storage": {
    "Type": "S3",
    "LocalRootPath": "storage"
  },
  "Persistence": {
    "Provider": "Json"
  },
  "AWS": {
    "Region": "ap-south-1",
    "Profile": "",
    "SharedCredentialsFile": "",
    "AccessKey": "",
    "SecretKey": "",
    "SessionToken": "",
    "BucketName": "remediation-tool-dev",
    "UseServerSideEncryption": true,
    "ServerSideEncryptionMethod": "AES256",
    "KmsKeyId": "",
    "DynamoDB": {
      "FindingsTableName": "RemediationFindings-dev",
      "HistoryTableName": "FindingHistory-dev",
      "JobAuditTableName": "IngestionJobAudit-dev",
      "RejectedRowsTableName": "RejectedRows-dev",
      "CheckpointsTableName": "IngestionCheckpoints-dev",
      "StagedFindingsTableName": "IngestionStagedFindings-dev"
    }
  },
  "IngestionProcessing": {
    "BatchSize": 1000,
    "MinBatchSize": 100,
    "MaxBatchSize": 10000,
    "EnableBatchCheckpointing": true,
    "MaxBatchPersistenceRetryCount": 3,
    "BatchPersistenceRetryDelayMilliseconds": 1000,
    "EnableParquetWorkingFile": true,
    "ParquetRowGroupSize": 10000
  }
}