{
  // Set Enabled=true only after the Entra API and Swagger app registrations
  // have been created and the values below are supplied for the environment.
  "Authentication": {
    "Enabled": false
  },
  // Development enables Swagger automatically. Other environments must opt in.
  "Swagger": {
    "Enabled": false
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "Audience": "",
    "Scopes": "access_as_user",
    "ApplicationRole": "access_as_application"
  },
  "SwaggerAzureAd": {
    "ClientId": "",
    "Scope": ""
  },
  "Authorization": {
    "Roles": {
      "SystemAdmin": "System_Admin",
      "Admin": "Admin",
      "User": "User",
      "ViewOnly": "View_Only"
    }
  },
  "Storage": {
    "Type": "S3",
    "LocalRootPath": "storage"
  },
  "Persistence": {
    "Provider": "DynamoDB",
    "JsonRootPath": "storage"
  },
  "AWS": {
    "Region": "us-east-2",
    "Profile": "saml",
    "SharedCredentialsFile": "",
    "AccessKey": "",
    "SecretKey": "",
    "SessionToken": "",
    "BucketName": "adp-gfr-edg-reports",
    "UseServerSideEncryption": true,
    "ServerSideEncryptionMethod": "AES256",
    "KmsKeyId": "",
    "DynamoDB": {
      "FindingsTableName": "gfr-edg-findings-dev",
      "JobAuditTableName": "gfr-edg-reports-dev",
      "RejectedRowsTableName": "gfr-edg-rejected-dev",
      "CheckpointsTableName": "gfr-ingestion-checkpoints-dev",
      "StagedFindingsTableName": "gfr-ingestion-staged-findings-dev",
      "MaxBatchWriteConcurrency": 4
    }
  },
  "IngestionProcessing": {
    "BatchSize": 5000,
    "MinBatchSize": 100,
    "MaxBatchSize": 10000,
    "EnableBatchCheckpointing": true,
    "MaxBatchPersistenceRetryCount": 3,
    "BatchPersistenceRetryDelayMilliseconds": 1000,
    "DynamoDbMaxConcurrentBatchWrites": 4,
    "EnableBoundedDynamoDbConcurrency": true,
    "DynamoDbWriteConcurrency": 4,
    "RejectedRowBatchSize": 5000,
    "EnableHighVolumeStreaming": false,
    "LegacyFallbackEnabled": true,
    "EnableParquetWorkingFile": true,
    "ValidateWorkingFileAfterWrite": true,
    "UseParquetAsPrimaryResumeStore": false,
    "LegacyStagingFallbackEnabled": true,
    "JobAuditProgressUpdateIntervalBatches": 1,
    "ParquetRowGroupSize": 50000,
    "CsvReaderBufferSize": 65536,
    "MaxUploadFileSizeMb": 500
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Amazon": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/remediationtool-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "flushToDiskInterval": "00:00:01",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{MachineName}] [{EnvironmentName}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "Properties": {
      "Application": "GFR-RemediationTool"
    }
  }
}
