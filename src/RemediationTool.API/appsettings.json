{
  "Storage": {
    "Type": "S3",
    "LocalRootPath": "storage"
  },
  "Persistence": {
    "Provider": "DynamoDB",
    "JsonRootPath": "storage"
  },
  "AWS": {
    "Region": "us-east-2",
    "Profile": "saml",
    "SharedCredentialsFile": "",
    "AccessKey": "",
    "SecretKey": "",
    "SessionToken": "",
    "BucketName": "gfr-edg-reports",
    "UseServerSideEncryption": true,
    "ServerSideEncryptionMethod": "AES256",
    "KmsKeyId": "",
    "DynamoDB": {
      "FindingsTableName": "gfr-file-findings-dev",
      "JobAuditTableName": "gfr-file-metadata-dev",
      "RejectedRowsTableName": "gfr-rejected-rows-dev",
      "CheckpointsTableName": "gfr-ingestion-checkpoints-dev",
      "StagedFindingsTableName": "gfr-ingestion-staged-findings-dev"
    }
  },
  "IngestionProcessing": {
    "BatchSize": 1000,
    "MinBatchSize": 100,
    "MaxBatchSize": 10000,
    "EnableBatchCheckpointing": true,
    "MaxBatchPersistenceRetryCount": 3,
    "BatchPersistenceRetryDelayMilliseconds": 1000,
    "EnableParquetWorkingFile": true,
    "ParquetRowGroupSize": 10000
  }
}